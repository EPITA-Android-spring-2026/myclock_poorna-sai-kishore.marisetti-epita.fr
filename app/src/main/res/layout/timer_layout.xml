<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:gravity="center"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color"
    android:padding="20dp">

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.5"/>

    <TextView
        android:id="@+id/timerTitle"
        android:text="Timer"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="25dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"/>

    <LinearLayout
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="35dp">

        <EditText
            android:id="@+id/timerMinutesInput"
            android:hint="MM"
            android:inputType="number"
            android:maxLength="2"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:background="@drawable/input_bg"
            android:textColor="@color/text_primary"
            android:layout_width="70dp"
            android:layout_height="55dp"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:text=":"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"/>

        <EditText
            android:id="@+id/timerSecondsInput"
            android:hint="SS"
            android:inputType="number"
            android:maxLength="2"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:background="@drawable/input_bg"
            android:textColor="@color/text_primary"
            android:layout_width="70dp"
            android:layout_height="55dp"
            android:layout_marginStart="12dp"/>

    </LinearLayout>

    <FrameLayout
        android:layout_width="300dp"
        android:layout_height="280dp"
        android:layout_marginBottom="35dp"
        android:background="@drawable/stopwatch_circle_bg"
        android:elevation="8dp"
        android:layout_gravity="center_horizontal">

        <LinearLayout
            android:orientation="vertical"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="20dp">

            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp">

                <TextView
                    android:id="@+id/timerMinutesText"
                    android:text="00"
                    android:textSize="60sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="75dp"
                    android:textAlignment="center"/>

                <TextView
                    android:text=":"
                    android:textSize="60sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="8dp"/>

                <TextView
                    android:id="@+id/timerSecondsText"
                    android:text="00"
                    android:textSize="60sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="75dp"
                    android:textAlignment="center"/>

            </LinearLayout>

            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <TextView
                    android:text="."
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/timerMillisecondsText"
                    android:text="00"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_color"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="50dp"
                    android:textAlignment="center"/>

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

    <!-- Button Container -->
    <LinearLayout
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp">

        <Button
            android:id="@+id/startTimerBtn"
            android:text="Start"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="@drawable/button_start_bg"
            android:layout_width="120dp"
            android:layout_height="55dp"
            android:layout_marginEnd="15dp"/>

        <Button
            android:id="@+id/stopTimerBtn"
            android:text="Pause"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="@drawable/button_stop_bg"
            android:layout_width="120dp"
            android:layout_height="55dp"
            android:layout_marginStart="15dp"
            android:enabled="false"/>

    </LinearLayout>

    <Button
        android:id="@+id/resetTimerBtn"
        android:text="Reset"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/text_secondary"
        android:background="@drawable/button_reset_bg"
        android:layout_width="150dp"
        android:layout_height="45dp"
        android:layout_marginBottom="20dp"/>

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.5"/>

</LinearLayout>